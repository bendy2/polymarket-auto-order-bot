# Polymarket 自动下单机器人配置
# 复制此文件为 .env 并填入你的凭证

# CLOB API 地址
CLOB_API_URL=https://clob.polymarket.com

# 链ID: 137=Polygon主网, 80002=Amoy测试网
CHAIN_ID=137

# 你的钱包私钥 (必填，用于签名)
PK=your_private_key_here

# Funder 地址 (如果你使用代理钱包，如Magic/Email钱包，需要填写实际持有资金的地址)
# FUNDER=0x...

# 签名类型: 
# 0 = 标准EOA钱包 (MetaMask/硬件钱包)
# 1 = Email/Magic钱包
# 2 = 浏览器代理钱包
SIGNATURE_TYPE=0

# 如果已经手动创建了API凭据，可以填写在这里，留空会自动生成
# CLOB_API_KEY=
# CLOB_SECRET=
# CLOB_PASS_PHRASE=
